#!/usr/bin/env python3
"""tplink-be7200 CLI launcher.

Adds the repo root to sys.path so the CLI runs without `pip install`.
"""
import os
import sys

HERE = os.path.dirname(os.path.realpath(__file__))
SDK = os.path.normpath(os.path.join(HERE, ".."))
sys.path.insert(0, SDK)

from tplink_be7200.cli import main

if __name__ == "__main__":
    main()
